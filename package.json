{
  "name": "pinpoint-extension",
  "version": "0.1.0",
  "description": "Annotate UI elements and generate AI-ready prompts",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "demo:serve": "python3 -m http.server 4173 --directory demo",
    "cws:check": "node scripts/chrome-web-store.mjs check",
    "cws:generate": "node scripts/chrome-web-store.mjs generate",
    "cws:package": "node scripts/chrome-web-store.mjs package",
    "cws:prepare": "npm run build && node scripts/chrome-web-store.mjs all",
    "cws:screenshots": "npm run build && playwright test tests/e2e/chrome-web-store-assets.spec.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npm run build && playwright test",
    "test:chrome": "npm run build && PINPOINT_BROWSER_CHANNEL=chrome playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
